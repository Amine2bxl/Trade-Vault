SUPABASE_PROJECT_ID=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=
GEMINI_API_KEY=

# --- Product analytics (client, optional) ---
# First-party PostHog HTTP capture (no SDK). Leave empty to disable entirely.
# Events are behavioral only — no trading data (PnL, symbols) is ever sent.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# --- AI provider (server-only) ---
# The app is provider-agnostic: it uses the first configured provider, or the
# one named by AI_PROVIDER. Tool-calling features require a tool-capable
# provider (openai or anthropic).
# AI_PROVIDER=            # optional: "gemini" | "anthropic" | "openai"
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-5
# OpenAI-compatible: works with OpenAI and any compatible endpoint (OpenRouter,
# Together, Groq, local vLLM/Ollama) by pointing OPENAI_BASE_URL at it.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- AI access (server-only) ---
# Paid gating switch. Leave empty / "false" during free early access so every
# signed-in user gets full AI access. Set to "true" to require an active Pro
# plan or trial once subscriptions launch.
AI_REQUIRE_PRO=false
# Per-user hourly cap on AI calls (abuse/cost protection, always on). Default 60.
AI_RATE_LIMIT_PER_HOUR=60

# --- Billing (server-only) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
COINBASE_COMMERCE_API_KEY=
COINBASE_COMMERCE_WEBHOOK_SECRET=

# --- Lifecycle emails (server-only) ---
RESEND_API_KEY=
EMAIL_FROM="TradeVault <hello@tradevault.app>"
PUBLIC_SITE_URL=https://tradevaultt.vercel.app

# --- Trustpilot TrustBox (public) ---
VITE_TRUSTPILOT_BUSINESS_UNIT_ID=
