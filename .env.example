# --- AI access (server-only) ---
# Paid gating switch. Leave empty / "false" during free early access so every
# signed-in user gets full AI access. Set to "true" to require an active Pro
# plan or trial once subscriptions launch.
AI_REQUIRE_PRO=false
# Per-user hourly cap on AI calls (abuse/cost protection, always on). Default 60.
AI_RATE_LIMIT_PER_HOUR=60

